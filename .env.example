# Copy this file to `.env.local` and fill in real values.
# Values here are consumed by `config/application.yml` at build time.

# Show the status pulse in the nav (true | false).
SHOW_STATUS=false

# Label shown next to the pulse when SHOW_STATUS=true.
STATUS_TEXT=Open to internships

# Public resume link used by the nav "Resume" button.
RESUME_URL=https://example.com/resume.pdf
