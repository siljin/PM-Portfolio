# Sanity content API (runtime app reads)
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_VERSION=2025-01-01
# Required for private / read-restricted datasets
SANITY_READ_TOKEN=

# Sanity Studio (hosted/local development — optional for app runtime)
SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=production
